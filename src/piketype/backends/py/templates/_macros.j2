{% macro scalar_alias(view) -%}
class {{ view.class_name }}:
    WIDTH = {{ view.width }}
    SIGNED = {{ "True" if view.signed else "False" }}
    BYTE_COUNT = {{ view.byte_count }}
{% if view.is_wide %}
    MAX_VALUE = {{ view.max_value }}

    def __init__(self, value: bytes | bytearray | int = b'') -> None:
        if isinstance(value, int):
            if value < 0 or value > self.MAX_VALUE:
                raise ValueError("{{ view.class_name }} value out of range")
            self.value = value.to_bytes(self.BYTE_COUNT, "big", signed=False)
            return
        if not isinstance(value, (bytes, bytearray)):
            raise TypeError("{{ view.class_name }} value must be bytes, bytearray, or int")
        raw = bytes(value)
        if len(raw) == 0:
            raw = b"\x00" * self.BYTE_COUNT
        if len(raw) != self.BYTE_COUNT:
            raise ValueError("{{ view.class_name }} value size mismatch")
        self.value = raw

    def _to_packed_int(self) -> int:
        return int.from_bytes(self.value, "big", signed=False)

    @classmethod
    def _from_packed_int(cls, packed: int) -> "{{ view.class_name }}":
        return cls(packed.to_bytes(cls.BYTE_COUNT, "big", signed=False))

    def to_bytes(self) -> bytes:
        return self.value

    @classmethod
    def from_bytes(cls, data: bytes | bytearray) -> "{{ view.class_name }}":
        if not isinstance(data, (bytes, bytearray)):
            raise TypeError("{{ view.class_name }}.from_bytes expects bytes or bytearray")
        raw = bytes(data)
        if len(raw) != cls.BYTE_COUNT:
            raise ValueError("{{ view.class_name }}.from_bytes size mismatch")
        # Mask padding bits in MSB byte
        masked = bytes([raw[0] & {{ view.msb_byte_mask }}]) + raw[1:]
        return cls(masked)

    def clone(self) -> "{{ view.class_name }}":
        return type(self)(self.value)

    def __eq__(self, other: object) -> bool:
        if isinstance(other, type(self)):
            return self.value == other.value
        if isinstance(other, (bytes, bytearray)):
            return self.value == bytes(other)
        return NotImplemented

    def __repr__(self) -> str:
        return f"{{ view.class_name }}(value={% raw %}{self.value!r}{% endraw %})"
{%- elif view.signed %}
    MIN_VALUE = {{ view.min_value }}
    MAX_VALUE = {{ view.max_value }}
    MASK = {{ view.mask }}
    SIGN_BIT = {{ view.sign_bit }}

    def __init__(self, value: int = 0) -> None:
        if not isinstance(value, int):
            raise TypeError("{{ view.class_name }} value must be int")
        if value < self.MIN_VALUE or value > self.MAX_VALUE:
            raise ValueError("{{ view.class_name }} value out of range")
        self.value = value

    def _to_packed_int(self) -> int:
        return self.value & self.MASK

    @classmethod
    def _from_packed_int(cls, packed: int) -> "{{ view.class_name }}":
        value = packed & cls.MASK
        signed_value = value - (1 << cls.WIDTH) if (value & cls.SIGN_BIT) else value
        return cls(signed_value)

    def to_bytes(self) -> bytes:
        mask = self.MASK
        packed = self.value & mask
        if self.value < 0:
            packed |= ((1 << (self.BYTE_COUNT * 8)) - 1) ^ mask
        return packed.to_bytes(self.BYTE_COUNT, "big", signed=False)

    @classmethod
    def from_bytes(cls, data: bytes | bytearray) -> "{{ view.class_name }}":
        if not isinstance(data, (bytes, bytearray)):
            raise TypeError("{{ view.class_name }}.from_bytes expects bytes or bytearray")
        raw = bytes(data)
        if len(raw) != cls.BYTE_COUNT:
            raise ValueError("{{ view.class_name }}.from_bytes size mismatch")
        raw_int = int.from_bytes(raw, "big", signed=False)
        data_bits = raw_int & cls.MASK
        padding = raw_int >> cls.WIDTH
        sign_bit = (data_bits >> (cls.WIDTH - 1)) & 1
        expected_padding = ((1 << {{ view.pad_bits }}) - 1) if sign_bit else 0
        if padding != expected_padding:
            raise ValueError("{{ view.class_name }}.from_bytes signed padding mismatch")
        return cls._from_packed_int(data_bits)

    def clone(self) -> "{{ view.class_name }}":
        return type(self)(self.value)

    def __int__(self) -> int:
        return self.value

    def __index__(self) -> int:
        return self.value

    def __eq__(self, other: object) -> bool:
        if isinstance(other, type(self)):
            return self.value == other.value
        if isinstance(other, int):
            return self.value == other
        return NotImplemented

    def __repr__(self) -> str:
        return f"{{ view.class_name }}(value={% raw %}{self.value!r}{% endraw %})"
{%- else %}
    MIN_VALUE = 0
    MAX_VALUE = {{ view.max_value }}

    def __init__(self, value: int = 0) -> None:
        if not isinstance(value, int):
            raise TypeError("{{ view.class_name }} value must be int")
        if value < self.MIN_VALUE or value > self.MAX_VALUE:
            raise ValueError("{{ view.class_name }} value out of range")
        self.value = value

    def _to_packed_int(self) -> int:
        return self.value

    @classmethod
    def _from_packed_int(cls, packed: int) -> "{{ view.class_name }}":
        return cls(packed)

    def to_bytes(self) -> bytes:
        return self.value.to_bytes(self.BYTE_COUNT, "big", signed=False)

    @classmethod
    def from_bytes(cls, data: bytes | bytearray) -> "{{ view.class_name }}":
        if not isinstance(data, (bytes, bytearray)):
            raise TypeError("{{ view.class_name }}.from_bytes expects bytes or bytearray")
        raw = bytes(data)
        if len(raw) != cls.BYTE_COUNT:
            raise ValueError("{{ view.class_name }}.from_bytes size mismatch")
        value = int.from_bytes(raw, "big", signed=False) & cls.MAX_VALUE
        return cls(value)

    def clone(self) -> "{{ view.class_name }}":
        return type(self)(self.value)

    def __int__(self) -> int:
        return self.value

    def __index__(self) -> int:
        return self.value

    def __eq__(self, other: object) -> bool:
        if isinstance(other, type(self)):
            return self.value == other.value
        if isinstance(other, int):
            return self.value == other
        return NotImplemented

    def __repr__(self) -> str:
        return f"{{ view.class_name }}(value={% raw %}{self.value!r}{% endraw %})"
{%- endif %}
{%- endmacro %}
