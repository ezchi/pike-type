    def to_bytes(self) -> bytes:
        return self.value.to_bytes(self.BYTE_COUNT, "big", signed=False)

    @classmethod
    def from_bytes(cls, data: bytes | bytearray) -> "{{ view.class_name }}":
        if not isinstance(data, (bytes, bytearray)):
            raise TypeError("{{ view.class_name }}.from_bytes expects bytes or bytearray")
        raw = bytes(data)
        if len(raw) != cls.BYTE_COUNT:
            raise ValueError("{{ view.class_name }}.from_bytes size mismatch")
        value = int.from_bytes(raw, "big", signed=False) & cls.MAX_VALUE
        return cls(value)

    def clone(self) -> "{{ view.class_name }}":
        return type(self)(self.value)

    def __int__(self) -> int:
        return self.value

    def __index__(self) -> int:
        return self.value

    def __eq__(self, other: object) -> bool:
        if isinstance(other, type(self)):
            return self.value == other.value
        if isinstance(other, int):
            return self.value == other
        return NotImplemented

    def __repr__(self) -> str:
        return f"{{ view.class_name }}(value={% raw %}{self.value!r}{% endraw %})"
{%- endif %}
