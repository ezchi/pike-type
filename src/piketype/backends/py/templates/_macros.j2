{% endfor %}

class {{ view.class_name }}:
    WIDTH = {{ view.width }}
    BYTE_COUNT = {{ view.byte_count }}

    def __init__(self, value: {{ view.enum_class_name }} = {{ view.enum_class_name }}.{{ view.first_member_name }}) -> None:
        if not isinstance(value, {{ view.enum_class_name }}):
            raise TypeError("{{ view.class_name }} value must be {{ view.enum_class_name }}")
        self.value = value

    def pack(self) -> int:
        return int(self.value)

    @classmethod
    def unpack(cls, packed: int) -> "{{ view.class_name }}":
        masked = packed & {{ view.mask }}
        try:
            enum_val = {{ view.enum_class_name }}(masked)
        except ValueError:
            raise ValueError("{{ view.class_name }}.unpack unknown enum value")
        return cls(enum_val)

    def to_bytes(self) -> bytes:
        return int(self.value).to_bytes({{ view.byte_count }}, "big", signed=False)

    @classmethod
    def from_bytes(cls, data: bytes | bytearray) -> "{{ view.class_name }}":
        if not isinstance(data, (bytes, bytearray)):
