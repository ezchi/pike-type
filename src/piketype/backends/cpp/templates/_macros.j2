{# Pack a narrow scalar value into the destination buffer at `offset`.
   `value_expr`: source value expression.
   `base`: the destination buffer name (e.g. "dst").
   `offset`: integer byte offset within base. #}
{% macro narrow_pack(view, value_expr, base, offset) -%}
{% if view.is_single_byte %}
{% if view.signed %}
    {{ base }}[{{ offset }}] = static_cast<uint8_t>({{ value_expr }});
{%- else %}
    {{ base }}[{{ offset }}] = {{ value_expr }};
{%- endif %}
{%- elif view.bswap_intrinsic %}
    {
{% if view.signed %}
      {{ view.bswap_uint_type }} be = {{ view.bswap_intrinsic }}(static_cast<{{ view.bswap_uint_type }}>({{ value_expr }}));
{%- else %}
      {{ view.bswap_uint_type }} be = {{ view.bswap_intrinsic }}({{ value_expr }});
{%- endif %}
      std::memcpy({{ base }} + {{ offset }}, &be, {{ view.byte_count }});
    }
{%- else %}
    {
      uint64_t bits = static_cast<uint64_t>({{ value_expr }});
      uint8_t* p = {{ base }} + {{ offset }};
      for (size_t i = 0; i < {{ view.byte_count }}; ++i) {
        p[{{ view.byte_count }} - 1 - i] = static_cast<uint8_t>((bits >> (8U * i)) & 0xFFU);
      }
    }
{%- endif %}
{%- endmacro %}


{# Load `byte_count` bytes from `base[offset .. offset+byte_count)` into a
   `uint64_t bits` local. #}
{% macro narrow_load_bits(view, base, offset) -%}
{% if view.is_single_byte %}
      uint64_t bits = {{ base }}[{{ offset }}];
{%- elif view.bswap_intrinsic %}
      {{ view.bswap_uint_type }} be;
      std::memcpy(&be, {{ base }} + {{ offset }}, {{ view.byte_count }});
      uint64_t bits = {{ view.bswap_intrinsic }}(be);
{%- else %}
      uint64_t bits = 0;
      const uint8_t* p = {{ base }} + {{ offset }};
      for (size_t i = 0; i < {{ view.byte_count }}; ++i) {
        bits = (bits << 8U) | p[i];
      }
{%- endif %}
{%- endmacro %}


