{% if f.is_struct_ref or f.is_flags_ref or f.is_enum_ref or f.is_scalar_ref %}
    {{ f.name }}.unpack_from(src + {{ f.byte_offset }});
{%- elif f.is_narrow_scalar and not f.needs_validate %}
{# Trivial native-width path. C++20 makes uintN→intN well-defined. #}
{% if f.is_single_byte %}
{% if f.signed %}
    {{ f.name }} = static_cast<{{ f.field_type_str }}>(src[{{ f.byte_offset }}]);
{%- else %}
    {{ f.name }} = src[{{ f.byte_offset }}];
{%- endif %}
{%- else %}
    {
      {{ f.bswap_uint_type }} raw;
      std::memcpy(&raw, src + {{ f.byte_offset }}, {{ f.byte_count }});
{% if f.signed %}
      {{ f.name }} = static_cast<{{ f.field_type_str }}>({{ f.bswap_intrinsic }}(raw));
{%- else %}
      {{ f.name }} = {{ f.bswap_intrinsic }}(raw);
{%- endif %}
    }
{%- endif %}
{%- elif f.is_narrow_scalar %}
{# Complex path: non-native width. #}
    {
{{ narrow_load_bits(f, "src", f.byte_offset) }}
{% if f.signed and f.has_signed_padding %}
      uint64_t data_bits = bits & {{ f.mask_literal }};
      bool sign_bit = ((data_bits >> {{ f.width - 1 }}U) & 1U) != 0U;
      uint64_t expected_pad = sign_bit ? (~static_cast<uint64_t>({{ f.mask_literal }}) & {{ f.byte_total_mask_literal }}) : 0ULL;
      if ((bits & ~static_cast<uint64_t>({{ f.mask_literal }}) & {{ f.byte_total_mask_literal }}) != expected_pad) {
        throw std::invalid_argument("{{ f.name }} signed padding mismatch");
      }
      bits = data_bits;
{% else %}
      bits &= {{ f.mask_literal }};
{% endif %}
{% if f.signed and f.has_signed_short_width %}
      int64_t signed_value = static_cast<int64_t>(bits);
      if ((bits & {{ f.sign_bit_literal }}) != 0U) {
        signed_value -= static_cast<int64_t>({{ f.full_range_literal }});
      }
      {{ f.name }} = static_cast<{{ f.field_type_str }}>(signed_value);
{% elif f.signed %}
      {{ f.name }} = static_cast<{{ f.field_type_str }}>(bits);
{% else %}
      {{ f.name }} = static_cast<{{ f.field_type_str }}>(bits);
{% endif %}
    }
{%- elif f.is_wide_scalar %}
    {
      std::memcpy({{ f.name }}.data(), src + {{ f.byte_offset }}, {{ f.byte_count }});
      {{ f.name }}[0] &= {{ f.msb_byte_mask_literal }};
    }
{%- endif %}
